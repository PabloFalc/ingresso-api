{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/modules/.*(-e2e\\.spec|\\.e2e-spec)\\.ts$",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.(t|j|mj)s$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": "<rootDir>/test/tsconfig.e2e.json"
      }
    ]
  },
  "transformIgnorePatterns": ["node_modules\\.pnpm(?!.*better-auth)"]
}
