# =============================================================================
# DESENVOLVIMENTO (copie para .env e preencha; nunca commite .env)
# =============================================================================

NODE_ENV="development"
PORT="3100"
HOST="0.0.0.0"

# BETTER AUTH - access token (mín. 32 caracteres). Produção: openssl rand -base64 32
BETTER_AUTH_SECRET="sua-chave-super-secreta-com-pelo-menos-32-caracteres"
BETTER_AUTH_URL="http://localhost:3100" # Mesma url da aplicação

# JWT – access token (mín. 32 caracteres). Produção: openssl rand -base64 32
JWT_SECRET="sua-chave-super-secreta-com-pelo-menos-32-caracteres"
JWT_EXPIRES_IN="7d"

# Cookie – refresh token (mín. 32 caracteres). Produção: outra chave segura
COOKIE_SECRET="outra-chave-super-secreta-com-pelo-menos-32-caracteres"
COOKIE_EXPIRES_IN="7d"

# CORS – origens permitidas (* em dev; em produção liste os domínios)
CORS_ORIGIN="*"

# PostgreSQL – URL completa. Ex.: postgresql://user:password@host:5432/database
DATABASE_URL="postgresql://docker:docker@localhost:5432/backend-pg"

# Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# =============================================================================
# TESTE (variáveis típicas para NODE_ENV=test; ajuste conforme seu setup)
# =============================================================================
# NODE_ENV=test
# DATABASE_URL=postgresql://...  # opcional: DB isolado para testes
# JWT_SECRET=...                  # mesmo ou chave de teste
# COOKIE_SECRET=...               # mesmo ou chave de teste

# =============================================================================
# PRODUÇÃO (nunca commitar valores reais; use secrets do servidor/CI)
# =============================================================================
# NODE_ENV=production
# PORT=3100
# HOST=0.0.0.0
# BETTER_AUTH_SECRET=...
# BETTER_AUTH_URL=http://localhost:3000 
# JWT_SECRET=...           # openssl rand -base64 32
# JWT_EXPIRES_IN=15m       # access token curto
# COOKIE_SECRET=...        # openssl rand -base64 32
# COOKIE_EXPIRES_IN=7d
# CORS_ORIGIN=https://seusite.com,https://www.seusite.com
# DATABASE_URL=postgresql://...
# REDIS_HOST=...
# REDIS_PORT=6379